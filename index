<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AVD Revival</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; background: #0a0a0a; }

    .page {
      min-height: 100vh;
      background: #0a0a0a;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 56px 24px 48px;
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      position: relative;
      overflow: hidden;
    }

    .hero-bg {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 52%;
      background: url('data:image/png;base64,') center bottom / cover no-repeat;
      opacity: 0.15;
      pointer-events: none;
      -webkit-mask-image: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.5) 40%, rgba(0,0,0,1) 100%);
      mask-image: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.5) 40%, rgba(0,0,0,1) 100%);
      z-index: 0;
    }

    .content {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 480px;
    }

    .logo-wrap {
      width: 200px;
      margin-bottom: 44px;
      filter: invert(1);
    }

    .logo-wrap img {
      width: 100%;
      height: auto;
      display: block;
    }

    .divider {
      width: 32px;
      height: 1px;
      background: #333;
      margin-bottom: 40px;
    }

    .links {
      display: flex;
      flex-direction: column;
      gap: 14px;
      width: 100%;
    }

    .link-btn {
      display: flex;
      align-items: center;
      gap: 16px;
      background: #111;
      border: 0.5px solid #242424;
      border-radius: 4px;
      padding: 18px 22px;
      color: #e0e0e0;
      text-decoration: none;
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-weight: 400;
      transition: background 0.2s ease, border-color 0.2s ease;
    }

    .link-btn:hover {
      background: #1a1a1a;
      border-color: #3a3a3a;
    }

    .link-btn .icon {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      opacity: 0.6;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .link-btn .icon svg {
      width: 20px;
      height: 20px;
      fill: #e0e0e0;
    }

    .link-btn .label { flex: 1; }

    .link-btn .arrow {
      opacity: 0.25;
      font-size: 14px;
    }

    .footer {
      margin-top: 56px;
      font-size: 10px;
      letter-spacing: 0.2em;
      color: #2a2a2a;
      text-transform: uppercase;
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="hero-bg"></div>
    <div class="content">

      <div class="logo-wrap">
        <img src="data:image/jpeg;base64," alt="AVD Revival" />
      </div>

      <div class="divider"></div>

      <div class="links">

        <a class="link-btn" href="https://www.avd-revival.com/" target="_blank" rel="noopener">
          <span class="icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
